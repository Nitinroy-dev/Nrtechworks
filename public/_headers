/assets/*.mp4
  Content-Type: video/mp4
  Cache-Control: public, max-age=31536000, immutable

/assets/*.webm
  Content-Type: video/webm
  Cache-Control: public, max-age=31536000, immutable

/assets/*.jpg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=31536000, immutable

/*
  X-Content-Type-Options: nosniff